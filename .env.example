# Copy this file to ~/.config/claude-outreach-loop/.env and fill in real values.
# Never commit the real .env.

export ATTIO_API_KEY=your_attio_api_key_here
export ATTIO_LIST_ID=uuid_of_your_outreach_list
export ATTIO_WORKSPACE_SLUG=your_workspace_slug

# Optional — where to cache discovered schema + record IDs
# Use $HOME (not ~) — tildes aren't expanded inside quoted env values at runtime.
export SCHEMA_PATH=$HOME/.config/claude-outreach-loop/schema.json
export DATA_DIR=$HOME/.config/claude-outreach-loop/data
