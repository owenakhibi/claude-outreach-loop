# Copy this file to ~/.config/claude-outreach-loop/.env and fill in real values.
# Never commit the real .env.

ATTIO_API_KEY=your_attio_api_key_here
ATTIO_LIST_ID=uuid_of_your_outreach_list
ATTIO_WORKSPACE_SLUG=your_workspace_slug

# Optional — where to cache discovered schema + record IDs
SCHEMA_PATH=~/.config/claude-outreach-loop/schema.json
DATA_DIR=~/.config/claude-outreach-loop/data
